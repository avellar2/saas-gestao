# ==========================================
# DATABASE
# ==========================================
# Local: postgresql://gestor:gestor123@localhost:5433/gestor_local
# Producao: postgresql://gestor:SENHA@postgres:5432/gestor_local
DATABASE_URL="postgresql://gestor:gestor123@localhost:5433/gestor_local?schema=public"

# Senha do PostgreSQL (usada no docker-compose.prod.yml)
POSTGRES_PASSWORD="gestor123"

# ==========================================
# NextAuth / Autenticação
# ==========================================
# Gere um secret seguro com: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret-in-production"

# URL base da aplicacao (sem barra no final)
# Local: http://localhost:3000
# Producao: https://avgestao.com.br
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# Email (Resend)
# ==========================================
# API Key em https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Email de envio (precisa verificar o dominio no Resend)
RESEND_FROM_EMAIL="noreply@avgestao.com.br"

# ==========================================
# Aplicacao
# ==========================================
NEXT_PUBLIC_APP_NAME="Gestor Local"
# Local: http://localhost:3000
# Producao: https://avgestao.com.br
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Stripe (pagamentos)
# ==========================================
# Chave secreta (Dashboard > Desenvolvedores > Chaves de API)
STRIPE_SECRET_KEY="sk_live_COLE_AQUI_SUA_CHAVE_SECRETA"

# Webhook secret (configurar depois do deploy)
# STRIPE_WEBHOOK_SECRET="whsec_COLE_AQUI_QUANDO_CONFIGURAR"

# IDs dos precos (Dashboard > Produtos > [produto] > ID do preco)
STRIPE_BASIC_PRICE_ID="price_COLE_AQUI_ID_DO_PRECO_BASICO"
STRIPE_PRO_PRICE_ID="price_COLE_AQUI_ID_DO_PRECO_PROFISSIONAL"

# ==========================================
# Sentry (monitoramento de erros - opcional)
# ==========================================
# DSN em https://sentry.io > Projetos > Gestor Local > Client Keys
SENTRY_DSN="https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@xxxxxx.ingest.sentry.io/xxxxxx"
SENTRY_ORG=""
SENTRY_PROJECT="gestor-local"

# ==========================================
# Rate Limiting (opcional)
# ==========================================
# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW_MS="60000"
