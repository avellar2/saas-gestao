# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5433/gestor_local?schema=public"

# ==========================================
# NextAuth / Autenticação
# ==========================================
# Gere um secret seguro com: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-secret-in-production"

# URL base da aplicação (sem barra no final)
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# Email (opcional - usado para recuperação de senha)
# ==========================================
# Provedor de email: resend | smtp
EMAIL_PROVIDER="resend"

# Resend API Key (obtenha em https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Domínio verificado no Resend (ex: resend.com ou seu domínio customizado)
RESEND_FROM_EMAIL="noreply@seudominio.com"

# SMTP fallback (se EMAIL_PROVIDER="smtp")
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seuemail@gmail.com"
SMTP_PASS="sua-senha-de-app"
SMTP_FROM="noreply@seudominio.com"

# ==========================================
# Aplicação
# ==========================================
NEXT_PUBLIC_APP_NAME="Gestor Local"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# Rate Limiting (opcional - sobrescreve defaults)
# ==========================================
# Rate limit por IP (requisições por minuto)
# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW_MS="60000"