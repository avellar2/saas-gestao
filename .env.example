# =================================================================
# AVGESTAO - Variaveis de ambiente
# =================================================================
# Copie este arquivo para .env e preencha com valores reais.
#
# GERACAO DE SECRETS:
#   openssl rand -base64 32    # gera secret de 32+ chars
#
# NUNCA commite o .env real.
# NUNCA use os placeholders deste arquivo em producao.
# =================================================================

# =================================================================
# DATABASE (PostgreSQL)
# =================================================================
# URL completa de conexao com o banco.
# Em Docker Compose, "postgres" e o nome do servico.
POSTGRES_USER="gestor"
POSTGRES_PASSWORD="GERAR_COM_OPENSSL_RAND_BASE64_24"
POSTGRES_DB="gestor_local"
DATABASE_URL="postgresql://gestor:GERAR_SENHA_FORTE@postgres:5432/gestor_local?schema=public"

# =================================================================
# NextAuth / Autenticacao
# =================================================================
# OBRIGATORIO em producao. Minimo 32 caracteres.
AUTH_SECRET="GERAR_COM_OPENSSL_RAND_BASE64_32"

# URL publica da aplicacao (sem barra no final)
# DEVE ser https:// em producao
NEXTAUTH_URL="https://avgestao.com.br"

# =================================================================
# Cron Jobs
# =================================================================
# OBRIGATORIO em producao. Minimo 16 caracteres.
# Protege /api/cron/* contra acesso publico.
CRON_SECRET="GERAR_COM_OPENSSL_RAND_BASE64_32"

# =================================================================
# Aplicacao
# =================================================================
NEXT_PUBLIC_APP_NAME="AVGESTAO"
NEXT_PUBLIC_APP_URL="https://avgestao.com.br"

# =================================================================
# Email (Resend)
# =================================================================
# OBRIGATORIO em producao se quiser enviar emails transacionais.
# Obtenha em https://resend.com
RESEND_API_KEY="re_GERAR_NO_RESEND"

# Email remetente. Dominio deve estar verificado no Resend.
RESEND_FROM_EMAIL="noreply@avgestao.com.br"

# =================================================================
# Stripe (pagamentos)
# =================================================================
# OBRIGATORIO em producao se quiser cobrar clientes.
# Use sk_live_ em producao, sk_test_ em dev.
STRIPE_SECRET_KEY="sk_live_GERAR_NO_STRIPE_DASHBOARD"

# Webhook secret (whsec_). Configure em:
# Dashboard Stripe > Desenvolvedores > Webhooks > Add endpoint
# URL: https://avgestao.com.br/api/stripe/webhook
# Eventos: checkout.session.completed, customer.subscription.*, invoice.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_GERAR_NO_STRIPE_DASHBOARD"

# IDs dos precos. Crie em Dashboard > Produtos.
STRIPE_BASIC_PRICE_ID="price_GERAR_NO_STRIPE_DASHBOARD"
STRIPE_PRO_PRICE_ID="price_GERAR_NO_STRIPE_DASHBOARD"

# =================================================================
# Sentry (monitoramento de erros - opcional)
# =================================================================
# Em producao, configure o DSN para receber alertas de erro.
# PII (senhas, tokens, emails) e filtrada via beforeSend.
SENTRY_DSN="https://GERAR_NO_SENTRY@INGEST.sentry.io/GERAR"
SENTRY_ORG="sua-org-no-sentry"
SENTRY_PROJECT="avgestao"

# =================================================================
# Seed Admin (obrigatorio se seed for rodar em producao)
# =================================================================
# Primeiro super admin criado pelo prisma db seed.
# A senha DEVE ter pelo menos 16 caracteres e nao ser placeholder.
SEED_ADMIN_EMAIL="admin@avgestao.com.br"
SEED_ADMIN_PASSWORD="GERAR_COM_OPENSSL_RAND_BASE64_24"
SEED_ADMIN_NAME="Admin AVGESTAO"

# =================================================================
# Rate Limiting (opcional)
# =================================================================
# Configuracao de rate limit via middleware.
# RATE_LIMIT_MAX="100"
# RATE_LIMIT_WINDOW_MS="60000"

# =================================================================
# VPS (apenas para scripts/remote.ps1 local)
# =================================================================
# Usado pelo wrapper local (Windows) que faz ssh na VPS.
# NUNCA commite valores reais aqui.
# Em .env (local, gitignored) preencha:
#   VPS_SERVER="86.48.24.70"
#   VPS_USER="root"
#   VPS_PORT="22"                            # opcional, default 22
#   VPS_PASSWORD="senha"                     # OU
#   VPS_KEY="C:\Users\voce\.ssh\id_rsa"      # caminho para chave privada
#   APP_DIR="/opt/gestor-local"              # opcional, default /opt/gestor-local
